# Conductor environment — copy: cp .env.example .env
# Generate secrets: openssl rand -hex 32

# ── Local dev (docker-compose) ────────────────────────────────
POSTGRES_PASSWORD=change_me            # openssl rand -hex 24
BOOTSTRAP_ADMIN_TOKEN=change_me        # openssl rand -hex 32 → local board login + admin API
APP_NAME=Conductor                     # brand name (UI)
DEFAULT_ORG=Demo                       # dev seed org (DEV_SEED only)
DEFAULT_PROJECT=default                # dev seed project (DEV_SEED only)

# ── Behavior toggles (sane local defaults in docker-compose) ──
# ENVIRONMENT: development | staging | production
# ALLOWED_ORIGINS: comma-separated allow-list. MUST be real domains in production
#   (never "*"). e.g. https://app.yourdomain.com,https://yourdomain.com
# REAPER_MODE: pgcron (prod) | inproc (local w/o pg_cron) | off (tests)
# DEV_SEED: seed Demo/default + admin locally. MUST be false in production.
# LOG_JSON: true in prod (Cloud Logging), false locally for readable logs.
# ALLOWED_ORIGINS=*
# REAPER_MODE=inproc
# DEV_SEED=true

# ── Production only (from Secret Manager, NOT this file) ──────
# DATABASE_URL=postgresql://user:pass@host/db      # control-plane / shared Postgres (Neon)
# Clerk (Phase 1 — dashboard/human auth). When unset, the Clerk-authed routes
# return 501 and the agent/MCP API keeps working standalone.
# CLERK_JWKS_URL=https://<your-app>.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER=https://<your-app>.clerk.accounts.dev
# CLERK_WEBHOOK_SECRET=whsec_...   # Svix signing secret for /api/webhooks/clerk
# Stripe (Phase 2 — billing is the on-switch). All three must be set for billing
# to activate; until then orgs are usable immediately (self-hosted mode) and the
# billing routes return 501. With billing on, a new org starts 'pending' and is
# unusable (402) until Stripe reports an active subscription.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # signing secret for /api/webhooks/stripe
# STRIPE_PRICE_ID=price_...         # the single paid plan
# BILLING_PLAN_NAME=pro             # label stored on orgs.plan
# PUBLIC_BASE_URL=https://app.example.com   # used for Stripe return URLs

# Error tracking (optional; nothing is sent when unset)
# SENTRY_DSN=https://...@...ingest.sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.05
