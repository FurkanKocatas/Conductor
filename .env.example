# Conductor environment — copy: cp .env.example .env
# Generate secrets: openssl rand -hex 32

# ── Local dev (docker-compose) ────────────────────────────────
POSTGRES_PASSWORD=change_me            # openssl rand -hex 24
BOOTSTRAP_ADMIN_TOKEN=change_me        # openssl rand -hex 32 → local board login + admin API
APP_NAME=Conductor                     # brand name (UI)
DEFAULT_ORG=Demo                       # dev seed org (DEV_SEED only)
DEFAULT_PROJECT=default                # dev seed project (DEV_SEED only)

# ── Behavior toggles (sane local defaults in docker-compose) ──
# ENVIRONMENT: development | staging | production
# ALLOWED_ORIGINS: comma-separated allow-list. MUST be real domains in production
#   (never "*"). e.g. https://app.yourdomain.com,https://yourdomain.com
# REAPER_MODE: pgcron (prod) | inproc (local w/o pg_cron) | off (tests)
# DEV_SEED: seed Demo/default + admin locally. MUST be false in production.
# LOG_JSON: true in prod (Cloud Logging), false locally for readable logs.
# ALLOWED_ORIGINS=*
# REAPER_MODE=inproc
# DEV_SEED=true

# ── Production only (from Secret Manager, NOT this file) ──────
# DATABASE_URL=postgresql://user:pass@host/db      # control-plane / shared Postgres (Neon)
# CLERK_JWKS_URL=...        # Phase 1
# CLERK_ISSUER=...          # Phase 1
# STRIPE_SECRET_KEY=...     # Phase 2
# STRIPE_WEBHOOK_SECRET=... # Phase 2
